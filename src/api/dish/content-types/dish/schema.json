{
  "kind": "collectionType",
  "collectionName": "dishes",
  "info": {
    "singularName": "dish",
    "pluralName": "dishes",
    "displayName": "Dish",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "minLength": 2
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "sku": {
      "type": "string",
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "vipPrice": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "costPrice": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "sold": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "rating": {
      "type": "decimal",
      "default": 0,
      "min": 0,
      "max": 5
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "dishes"
    },
    "orderItems": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "dish_id"
    }
  }
}
