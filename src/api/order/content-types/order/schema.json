{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "order_no": {
      "type": "uid"
    },
    "table_id": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::table.table",
      "inversedBy": "orders"
    },
    "order_status": {
      "type": "enumeration",
      "enum": [
        "empty",
        "active",
        "paid",
        "outstanding",
        "cancelled",
        "refunded"
      ],
      "default": "active"
    },
    "source": {
      "type": "enumeration",
      "enum": [
        "dine_in",
        "takeaway",
        "delivery"
      ],
      "default": "dine_in"
    },
    "guest_count": {
      "type": "integer",
      "default": 1,
      "min": 1
    },
    "is_paid": {
      "type": "boolean",
      "default": false
    },
    "opened_at": {
      "type": "datetime"
    },
    "paid_time": {
      "type": "datetime"
    },
    "closed_at": {
      "type": "datetime"
    },
    "subtotal": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "discount_amount": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "tax_amount": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "service_charge": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "total_amount": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "paid_amount": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "change_amount": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "cashier_name": {
      "type": "string"
    },
    "customer_name": {
      "type": "string"
    },
    "note": {
      "type": "text"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "order_id"
    },
    "payments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::payment.payment",
      "mappedBy": "order_id"
    }
  }
}
