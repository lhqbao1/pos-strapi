{
  "kind": "collectionType",
  "collectionName": "tables",
  "info": {
    "singularName": "table",
    "pluralName": "tables",
    "displayName": "Table",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "tableNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "displayName": {
      "type": "string"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "Normal",
        "Vip"
      ],
      "default": "Normal"
    },
    "table_status": {
      "type": "enumeration",
      "enum": [
        "Empty",
        "Using",
        "Reserved",
        "Cleaning",
        "Disabled"
      ],
      "default": "Empty"
    },
    "capacity": {
      "type": "integer",
      "default": 4,
      "min": 1
    },
    "zone": {
      "type": "string"
    },
    "note": {
      "type": "text"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "occupied_since": {
      "type": "datetime"
    },
    "last_cleared_at": {
      "type": "datetime"
    },
    "orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order.order",
      "mappedBy": "table_id"
    }
  }
}
